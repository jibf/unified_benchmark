# AgentHard Benchmark Suite Environment Configuration
# Copy this file to .env and fill in your API credentials
#
# IMPORTANT: All models must be OpenAI API compatible

# ========================
# REQUIRED CONFIGURATION
# ========================

# Primary Agent Model Configuration (Required)
API_KEY=your_api_key_here
BASE_URL=your_openai_compatible_endpoint_url

# RAPID_API Configuration (Required for some benchmarks)
# Used by CFBench and ToolSandbox for web search functionality
RAPID_API_KEY=your_rapid_api_key_here

# User Model Configuration (Optional)
# Used by benchmarks that need separate user simulation (ToolSandbox, TauBench, ACEBench)
# If not specified, defaults to same as agent model
USER_API_KEY=your_user_api_key_here
USER_BASE_URL=your_user_model_endpoint_url

# ========================
# USAGE EXAMPLES
# ========================

# OpenAI:
# BASE_URL=https://api.openai.com/v1

# Local vLLM server:
# BASE_URL=http://localhost:8000/v1

# Any OpenAI-compatible endpoint:
# BASE_URL=your_custom_openai_compatible_endpoint/v1